{
  "name": "instabridge",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "description": "Instabridge is a RESTful backend API built with Node.js, TypeScript, and Express that acts as a structured and efficient bridge between your application and the Instagram Graph API.",
  "author": {
    "name": "Diego Libonati",
    "email": "diego.libonati1998@gmail.com"
  },
  "main": "dist/server.js",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.app.json src/server.ts",
    "build": "tsc -p tsconfig.app.json && tsc-alias -p tsconfig.app.json",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:all": "eslint src __tests__ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "format:all": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "type-check": "tsc -p tsconfig.app.json --noEmit",
    "test": "jest --runInBand --verbose",
    "test:watch": "jest --runInBand --watchAll --verbose",
    "test:coverage": "jest --runInBand --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "express": "^4.21.0",
    "morgan": "^1.10.1",
    "redis": "^4.6.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "jest": "^30.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.0.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
